#!/bin/bash

TOKEN_FILE="$(dirname "$0")/.token"

if [ ! -f "$TOKEN_FILE" ]; then
  echo "Error: .token file not found at $TOKEN_FILE"
  echo "Create it with your GitHub Personal Access Token:"
  echo "  echo 'ghp_yourtoken' > .token"
  exit 1
fi

export GH_TOKEN
GH_TOKEN=$(cat "$TOKEN_FILE")

PINNED_VERSION="1.0.7"
LATEST_VERSION=$(npm view @github/copilot version 2>/dev/null)
echo "Copilot version: pinned=${PINNED_VERSION}, latest=${LATEST_VERSION}"
if [ "$LATEST_VERSION" != "$PINNED_VERSION" ]; then
  echo "  *** A newer version (${LATEST_VERSION}) is available ***"
fi

run() { COPILOT_AUTO_UPDATE=false npx --yes @github/copilot@${PINNED_VERSION} --allow-all-tools "$@"; }

run "$@" || {
  echo "rm -rf ~/.npm/_npx/*/node_modules/@github/copilot*"
  run "$@"
}
